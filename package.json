{
  "name": "ravenswatch-talent-helper",
  "version": "1.0.0",
  "description": "A web app that shows you what talents are still available for your character during a Ravenswatch run. Helps decide whether it is worth spending a reroll during a level up.",
  "keywords": [
    "Ravenswatch",
    "Game",
    "Talents",
    "Calculator",
    "Builder",
    "Tool",
    "Helper"
  ],
  "scripts": {
    "dev": "concurrently -k -n VITE,\"TSC \" -c green,blue --prefix \"{name} |\" \"vite\" \"tsc --noEmit --watch --pretty\"",
    "build": "vite build",
    "generateManualTalentsTemplate": "tsx src/scripts/talents/generateManualTalentsTemplate/generateManualTalentsTemplate",
    "generateTalents": "tsx src/scripts/talents/generateTalents/generateTalents",
    "downloadTalentIcons": "tsx src/scripts/talents/downloadTalentIcons/downloadTalentIcons",
    "optimizeTalentIcons": "tsx src/scripts/talents/optimizeTalentIcons",
    "optimizeHeroIcons": "tsx src/scripts/optimizeHeroIcons",
    "generateMagicalObjects": "tsx src/scripts/objects/generateMagicalObjects/generateMagicalObjects",
    "downloadObjectIcons": "tsx src/scripts/objects/downloadObjectIcons",
    "optimizeObjectIcons": "tsx src/scripts/objects/optimizeObjectIcons",
    "random": "tsx src/scripts/random.ts",
    "randomWatch": "tsx watch src/scripts/randomWatch.ts"
  },
  "homepage": "https://github.com/kolesan/ravenswatch-talent-helper#readme",
  "bugs": {
    "url": "https://github.com/kolesan/ravenswatch-talent-helper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolesan/ravenswatch-talent-helper.git"
  },
  "license": "ISC",
  "author": "Konstantin Lebedev",
  "type": "module",
  "dependencies": {
    "clsx": "^2.1.1",
    "htm": "^3.1.1",
    "lodash.debounce": "^4.0.8",
    "preact": "^10.28.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@types/jsdom": "^27.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.0.2",
    "concurrently": "^9.2.1",
    "jsdom": "^27.3.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-bundle-analyzer": "^1.3.2"
  }
}
